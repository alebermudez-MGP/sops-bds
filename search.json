{ "title": "Chirp Review Process — Purpose", "url": {{ "/chirp-review#sec1" | relative_url | jsonify }}, "content": "Purpose of the Chirp SOP. How UW reviews completed Chirp verifications, identifies banking or creditor findings, documents in Salesforce, handles Bank Refresh for returned payments. Escalate to UW Management if there is doubt." },
{ "title": "Chirp Review Process — Scope", "url": {{ "/chirp-review#sec2" | relative_url | jsonify }}, "content": "Scope of the Chirp SOP. Applies to new Chirp verifications, Chirp findings during UW review, Bank Refresh returned payment reviews, files needing Sales CS Accounting UW Management involvement. Applies to both BDS and DAG portfolios." },
{ "title": "Chirp Review Process — When to Review Chirp", "url": {{ "/chirp-review#sec3" | relative_url | jsonify }}, "content": "No system notification when a client completes Chirp. Review Chirp several times per day. Chirp portal login credentials provided by Management. Do not share credentials without approval." },
{ "title": "Chirp Review Process — How to Find a File in Chirp", "url": {{ "/chirp-review#sec4" | relative_url | jsonify }}, "content": "Go to Request menu, review only Initial Status Verified files, compare customer name against the Chirp control GSheet. If customer already listed do not work it again. Add reviewer name and review date." },
{ "title": "Chirp Review Process — Required Salesforce Update", "url": {{ "/chirp-review#sec5" | relative_url | jsonify }}, "content": "Update the Completed Chirped Link field in the Underwriting section with the date the client completed Chirp. This step cannot be skipped." },
{ "title": "Chirp Review Process — Open the Chirp Request", "url": {{ "/chirp-review#sec6" | relative_url | jsonify }}, "content": "Click the hyperlink under Code. Use only Response Information Returned. Do not use Request Information Entered." },
{ "title": "Chirp Review Process — Banking Information Review", "url": {{ "/chirp-review#sec7" | relative_url | jsonify }}, "content": "Review account number, routing number, account name, owner name, and all accounts in the dropdown. Account matches continue review. Mismatch contact Sales. Bank completely different. Credit Union FCU mismatch. Account seems to belong to another person or business." },
{ "title": "Chirp Review Process — Account Number Mismatch", "url": {{ "/chirp-review#sec8" | relative_url | jsonify }}, "content": "Account number in Chirp does not match Salesforce or banking documents. Contact Sales. Provide banking docs or complete a new Chirp with the account on file." },
{ "title": "Chirp Review Process — Routing Number Mismatch", "url": {{ "/chirp-review#sec9" | relative_url | jsonify }}, "content": "Account number matches but routing number does not match. Ask Sales to clarify the discrepancy. Escalate to UW Management if unclear." },
{ "title": "Chirp Review Process — Different Bank in Chirp", "url": {{ "/chirp-review#sec10" | relative_url | jsonify }}, "content": "Salesforce shows one bank, Chirp shows a completely different bank. Sales confirms client completes Chirp with bank on file or provides banking docs for the bank used in Chirp." },
{ "title": "Chirp Review Process — Credit Union / FCU Accounts", "url": {{ "/chirp-review#sec11" | relative_url | jsonify }}, "content": "Credit Union and FCU accounts may show the account number differently. Review case by case, request a bank statement, validate account type." },
{ "title": "Chirp Review Process — Account Name and Owner Name", "url": {{ "/chirp-review#sec12" | relative_url | jsonify }}, "content": "Account name should match the business. Confirm owner name. Sole proprietor exception. Review documents, business connection, no indication documents were modified." },
{ "title": "Chirp Review Process — Deposits and Withdrawals Review", "url": {{ "/chirp-review#sec13" | relative_url | jsonify }}, "content": "Scroll to Deposits and Withdrawals. Check if any enrolled creditor made recent deposits. Review all accounts, compare creditor name, amount, date, description." },
{ "title": "Chirp Review Process — Creditor Tenure Rules", "url": {{ "/chirp-review#sec14" | relative_url | jsonify }}, "content": "30 natural days standard tenure, 25 days exception. 45 natural days standard, 40 days exception. Natural days include weekends. Exception tenure requires UW Management approval." },
{ "title": "Chirp Review Process — Creditor Close to Tenure", "url": {{ "/chirp-review#sec15" | relative_url | jsonify }}, "content": "Creditor close to meeting the tenure requirement. Leave a note, add the next step date, work that creditor last, continue after the eligible date." },
{ "title": "Chirp Review Process — Recent Funding Found", "url": {{ "/chirp-review#sec16" | relative_url | jsonify }}, "content": "One creditor only cannot continue, notify Sales, notify UW Management if card payment exists. Multiple creditors: remove the non qualifying creditor, recalculate debt, confirm term, send updated contract, client must redo the PW Call Pre Welcome Call." },
{ "title": "Chirp Review Process — If Debt Drops Below the Minimum", "url": {{ "/chirp-review#sec17" | relative_url | jsonify }}, "content": "Removing a creditor drops the remaining debt below the program minimum. File cannot continue, move to not qualified status, notify Sales, notify UW Management and Accounting if payment already exists." },
{ "title": "Chirp Review Process — Same Creditor With Multiple Positions", "url": {{ "/chirp-review#sec18" | relative_url | jsonify }}, "content": "Creditor has multiple positions enrolled and one deposit found. Do not remove all positions automatically. Ask Sales which position the deposit belongs to and remove only that position." },
{ "title": "Chirp Review Process — Card Payment and ACH Handling", "url": {{ "/chirp-review#sec19" | relative_url | jsonify }}, "content": "If card payment already processed do not create a new PayNow. Notify UW Management for Accounting adjustment. ACH same day 1 PM EST cutoff." },
{ "title": "Chirp Review Process — Files That Need to Be Placed on Hold", "url": {{ "/chirp-review#sec20" | relative_url | jsonify }}, "content": "Stage Underwriting, Status Returned File Needs Review. Email CS to pause payments, explain the reason, provide resume date if known." },
{ "title": "Chirp Review Process — Creditor Name Differences", "url": {{ "/chirp-review#sec21" | relative_url | jsonify }}, "content": "Creditor name in Chirp does not match Salesforce exactly. DBA, servicing name, descriptor, related entity. Expansion Capital Group, One River Funding, Biz2Credit, Lendini Funding Metrics, MCA Funding Servicing. Validate using the creditor GSheet." },
{ "title": "Chirp Review Process — Transactions That May Not Be New Funding", "url": {{ "/chirp-review#sec22" | relative_url | jsonify }}, "content": "Returned ACH payments, reversed deductions, PMNT RCVD, small adjustments, card processor deposits, Stripe deposits. Review carefully before treating a deposit as new funding." },
{ "title": "Chirp Review Process — When the Lender Does Not Show in Transactions", "url": {{ "/chirp-review#sec23" | relative_url | jsonify }}, "content": "The enrolled lender does not always appear in Chirp transactions. Not automatically an issue if banking information matches and no recent funding is found." },
{ "title": "Chirp Review Process — Bank Refresh for Returned Payments", "url": {{ "/chirp-review#sec24" | relative_url | jsonify }}, "content": "Client Returned Payment email subject. Bank Refresh button active or green — click refresh and confirm balance. Greyed out — tell CS refresh not available. No completed Chirp — tell CS balance cannot be confirmed." },
{ "title": "Chirp Review Process — Salesforce Notes", "url": {{ "/chirp-review#sec25" | relative_url | jsonify }}, "content": "Document every Chirp review with review date, Completed Chirped Link, banking result, account name, owner name, creditor activity, funding date, action taken, Sales or CS notification, updated contract, Bank Refresh result." },
{ "title": "Chirp Review Process — Final Checklist", "url": {{ "/chirp-review#sec26" | relative_url | jsonify }}, "content": "Chirp control sheet updated, Completed Chirped Link updated, Response section reviewed not Request, account number routing account name owner name reviewed, all accounts reviewed, deposits withdrawals reviewed, recent funding ruled out, Sales CS notified, updated contract sent, Salesforce notes added." }
]
